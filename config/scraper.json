{
  "input_glob": "data/01_discovered/*.jsonl",
  "output_dir": "data/02_raw_articles",
  "sources_config": "config/sources.json",
  "timezone": "Asia/Ho_Chi_Minh",
  "resume": true,
  "http": {
    "timeout_sec": 20,
    "retries": 2,
    "delay_between_requests_sec": 1.0,
    "concurrency": 5
  },
  "browser": {
    "enabled": true,
    "timeout_sec": 35,
    "concurrency": 2,
    "wait_until": "domcontentloaded",
    "delay_before_return_html_sec": 0.5,
    "wait_for_timeout_ms": 15000,
    "headless": true,
    "enable_stealth": true
  }
}
